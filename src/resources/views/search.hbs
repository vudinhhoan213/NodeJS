<div class="mt-4">
  <form method="POST" , action="">
    <div class="form-input">
      <label for="search-input">Từ khóa</label>
      <input
        type="text"
        class="form-control"
        name="hoan"
        placeholder="Nhập vào từ khóa..."
        aria-describedby="emailHelp"
      />
    </div>
    <div class="form-group">
      <label for="search-group">Giới tính</label>
      <select class="form-control" name="gender">
        <option value=""></option>
        <option value="fale">Nam</option>
        <option value="male">Nữ</option>
      </select>
    </div>
    <div class="mt-2"><button
        type="submit"
        class="btn btn-primary"
      >Submit</button></div>

  </form>
</div>